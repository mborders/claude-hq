# ----- Host UID/GID (REQUIRED on Linux; recommended on macOS Docker Desktop) -----
# Shells do NOT export these by default, so Compose can't read them unless they're
# in this file. Seed with:
#   printf 'UID=%s\nGID=%s\n' "$(id -u)" "$(id -g)" >> .env
UID=
GID=

# ----- Host port the app is served on -----
HOST_PORT=7878

# ----- Host paths to mount (defaults match a standard macOS setup) -----
# Global Claude config directory (leave blank to use ${HOME}/.claude):
HOST_CLAUDE_HOME=
# Projects root to scan for project-level .claude/ (leave blank to use ${HOME}/Documents/GitHub):
HOST_PROJECTS_ROOT=

# ----- App-layer safety switch -----
# true  = backend refuses ALL writes (pair with the :ro mount for hard enforcement)
# false = editing + backups enabled
READ_ONLY=false
