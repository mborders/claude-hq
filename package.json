{
  "name": "claude-ctl",
  "version": "0.1.0",
  "type": "module",
  "description": "A sleek local web UI to manage global and project-level Claude Code configuration — run it with npx.",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "config",
    "configuration",
    "cli",
    "mcp",
    "skills"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mborders/claude-control.git"
  },
  "homepage": "https://github.com/mborders/claude-control#readme",
  "bin": {
    "claude-ctl": "bin/claude-ctl.cjs"
  },
  "files": [
    "bin/claude-ctl.cjs",
    "server/dist/server.cjs",
    "web/dist"
  ],
  "engines": {
    "node": ">=20.11 <23"
  },
  "workspaces": [
    "shared",
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -k -n web,api -c blue,magenta \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "npm run dev -w @ccm/web",
    "dev:server": "npm run dev -w @ccm/server",
    "build": "npm run build:web && npm run build:server",
    "build:web": "npm run build -w @ccm/web",
    "build:server": "npm run build -w @ccm/server",
    "start": "node server/dist/server.cjs",
    "prepublishOnly": "npm run build",
    "typecheck": "npm run typecheck -w @ccm/shared && npm run typecheck -w @ccm/server && npm run typecheck -w @ccm/web",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "overrides": {
    "vite": "^6.0.7"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "fastify": "^5.2.0",
    "fflate": "^0.8.3",
    "js-yaml": "^4.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
